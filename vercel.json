{
  "version": 2,
  "builds": [
    {
      "src": "JS/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "img/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "JS/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}